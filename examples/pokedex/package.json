{
  "name": "pokedex-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Demo app: Pokédex powered by mongo-autorest, with 1,025 Pokémon, battle simulator, and team builder",
  "scripts": {
    "start": "node server.mjs",
    "seed": "node -e \"import('./seed.mjs').then(m => m.seedDatabase(process.env.MONGO_URI || 'mongodb://localhost:27017/pokedex'))\""
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "mongo-autorest": "github:matthew-gerstman/mongo-autorest",
    "mongodb": "^6.12.0",
    "mongodb-memory-server": "^10.1.2"
  }
}
